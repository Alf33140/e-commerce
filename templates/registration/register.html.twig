{% extends 'base.html.twig' %}

{% block body %}
<div class="container containerform">
        
        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm, {'attr': {'class': 'login-form'}}) }}
            <h1>Register</h1>
            
            {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control form mt3', 'placeholder':'email'}}) }}
            {{ form_widget(registrationForm.lastname, {'attr': {'class': 'form-control', 'placeholder':'lastname'}}) }}
            {{ form_widget(registrationForm.firstname, {'attr': {'class': 'form-control', 'placeholder':'firstname'}}) }}
            {{ form_widget(registrationForm.plainPassword, {
                label: 'Password', 'attr': {'class': 'form-control', 'placeholder':'Mot de passe'}}) }}
            
            {{ form_row(registrationForm.agreeTerms, {'label': 'Veuillez accepter les conditions'}) }}

            <button type="submit" class="btn btn-lg btn-primary btn-w-100 mt-4">Register</button>
        {{ form_end(registrationForm) }}
</div>

{% endblock %}
