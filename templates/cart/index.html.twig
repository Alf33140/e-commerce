{% extends 'base.html.twig' %}

{% block title %}Hello CartController!{% endblock %}

{% block body %}
    <div class="container">
        <h1>Panier✅</h1>
        <table class="table table_bordered">
            <tr>
                <th>Produit:</th>
                <th>Prix:</th>
                <th>Quantité:</th>
                <th>Prix total:</th>
                <th>Action:</th>
            </tr>
            
                {% for item in items %}
                    <tr>
                        <td> {{ item.product.name }}</td>
                        <td> {{ item.product.price }}</td>
                        <td> {{ item.quantity }}</td>
                        <td> {{ item.product.price * item.quantity }}</td>
                        <td>
                            <a href="{{ path('app_cart_delete',{'id':item.product.id})}}" class="text-danger">Supprimer du Panier</a>
                        </td>
                    </tr>
                    {% else %}
                        <p>Votre panier est vide</p>
                {% endfor %}
                
        </table> 
        
            <h2>Votre total:</h2>
                <div class="row">
                    <a href=" " class="btn btn-success col-2 mt-2" >Valider le panier</a>
                    <a href="{{ path('app_remove_all_cart') }}" class="btn btn-danger col-2 mt-2" >Supprimer le panier</a>
                </div> 
    </div>
    
{% endblock %}
