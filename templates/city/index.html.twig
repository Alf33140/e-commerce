{% extends 'base.html.twig' %}

{% block title %}Cost index{% endblock %}

{% block body %}
<div class="container">
    <h1>Cost index</h1>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Id</th>
                <th>Ville</th>
                <th>Frais de port</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for cost in costs %}
            <tr>
                <td>{{ cost.id }}</td>
                <td>{{ cost.city }}</td>
                <td>{{ cost.cost }}</td>
                <td>
                    <a href="{{ path('app_city_show', {'id': cost.id}) }}">Voir</a>
                    <a href="{{ path('app_city_edit', {'id': cost.id}) }}">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucune ville trouvée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_city_new') }}">Creer une nouvelle ville</a>
</div>
{% endblock %}
