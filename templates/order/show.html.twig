{% extends 'base.html.twig' %}

{% block title %}Order{% endblock %}

{% block body %}
    <div class="container">
        <h1>Commande</h1>
        
            <table class="table table-bordered">
                <tbody>
                    <tr>
                        <th>Id</th>
                        <td>{{ order.id }}</td>
                    </tr>
                    <tr>
                        <th>FirstName</th>
                        <td>{{ order.firstName }}</td>
                    </tr>
                    <tr>
                        <th>LastName</th>
                        <td>{{ order.lastName }}</td>
                    </tr>
                    <tr>
                        <th>Phone</th>
                        <td>{{ order.phone }}</td>
                    </tr>
                    <tr>
                        <th>Adresse</th>
                        <td>{{ order.Adresse }}</td>
                    </tr>
                    <tr>
                        <th>CreatedAt</th>
                        <td>{{ order.createdAt ? order.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                    </tr>
                </tbody>
            </table>

            <a href="{{ path('app_order_index') }}">Revenir à la liste</a>

            <a href="{{ path('app_order_edit', {'id': order.id}) }}">Modifier</a>

            {{ include('order/_delete_form.html.twig') }}
    </div>
{% endblock %}
