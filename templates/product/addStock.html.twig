{% extends 'base.html.twig' %}

{% block title %}Ajouter du stock {% endblock %}

{% block body %}
    <div class="container">
        <h1>Ajouter du stock pour le produit {{ product.name }}</h1> {#on affiche un titre indiquant que nous sommes sur la page d'ajout de stock pour un produit spécifique, en utilisant le nom du produit pour personnaliser le titre. #}
        
        {{ form_start(form) }} {#on démarre le formulaire en utilisant la fonction form_start, qui génère le code HTML nécessaire pour afficher le formulaire. #}
            {{ form_row(form.quantity, {'attr': {'class': 'form form-control mb-3'}}) }} {#on affiche le champ de saisie pour la quantité de stock à ajouter, en utilisant la fonction form_row pour générer le code HTML du champ. On ajoute également des classes CSS pour styliser le champ de saisie. #}
            <input type="submit" class='btn btn-success btn-block' > {#on ajoute un bouton de soumission pour le formulaire, avec des classes CSS pour le styliser. #}
        {{ form_end(form) }}
    </div>
{% endblock %}