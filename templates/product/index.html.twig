{% extends 'base.html.twig' %}

{% block title %}Listes des produits estampilés WEST POINT à la vente:{% endblock %}

{% block body %}
    <div class="container">
        <h1>Liste des produits</h1>
        {{ include('layout/_flash_message.html.twig') }}
        <table class="table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nom du produit</th>
                    <th>Description du produit</th>
                    <th>Prix (en thunes)</th>
                    <th>Stock</th>
                    <th>actions</th>
                </tr>
            </thead>
            <tbody>
            {% for product in products %}
                <tr>
                    <td>{{ product.id }}</td>
                    <td>{{ product.name }}</td>
                    <td>{{ product.descriptionproduct|slice(0,60) }}...</td>
                    <td>{{ product.Price }}</td>
                    <td>
                    {% if product.stock > 0 %}
                       {{product.stock}}
                    {% else %}
                        <span class="text-danger">Rupture de stock</span>
                    {% endif %}
                    </td>
                    <td class="d-flex align-items-center gap-2"> // d-flex align-items-center gap-2 pour espacer les boutons
                        <a href="{{ path('app_product_show', {'id': product.id}) }}" class="btn btn-success">Montrer</a>
                        <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-primary">Modifier</a>
                        {{ include("product/_delete_form.html.twig") }}
                        <a class="btn btn-outline-info mt-2" href="">Ajouter du stock
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">Pas de produits trouvés</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <a href="{{ path('app_product_new') }}">Rentrer un produit</a>
    </div>
{% endblock %}
