{% extends 'base.html.twig' %}

{% block title %}Page Produit{% endblock %}

{% block body %}
            <div class='container login-form'>
                <h1>Fiche Produit: </h1>
                
                <div class="card mb-3" style="max-width: 540px;">
                    <div class="row no-gutters">
                        <div class="col-md-4">
                        <img src="{{ asset('uploads/'~product.images)}}" class="card-img" alt="...">
                        </div>
                        <div class="col-md-8">
                        <div class="card-body">
                            <h5 class="card-title">{{ product.name }}</h5>
                            <p class="card-text">{{ product.description }}</p>
                            <a href="" class="btn btn-dark">Ajouter au panier</a>
                            <p class="card-text"><small class="text-body-secondary">Last updated 3 mins ago</small></p>
                        </div>
                            
                        </div>
                    </div>
                    </div> 
                    
                </div>
                <h2>Derniers Produits ajoutés:</h2>
            </div>
            <div class="row">
                {% for product in lastProductAdded %}
                    <div class="col-md-3 mt-4"> 
                        <div class="card" style="width: 18rem;">
                            <img src="{{asset('uploads/'~product.images)}}" class="imgproduct card-img">
                            <div class="card-body">
                                <a class"titleProductLink" href="app_home_product_show",{'id':lastProductsAdded}></a>
                                <p class="card-text">{{ product.description|slice(0,60)}} </p>
                                <p class="card-text">{{ product.price }} Thunes</p>
                                <p class="card-text">Stock: {{ product.stock }}</p>
                                <a href="" class="btn btn-dark">Ajouter au panier</a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
{% endblock %}