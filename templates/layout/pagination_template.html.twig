{% if pageCount > 1 %}
<nav aria-label="Page navigation example">
  <ul class="pagination justify-content-center">
    {% if previous is defined %}
    <li class="page-item">
      <a href="{{ path(route, query|merge({(pageParameterName):previous})) }}" class="page-link">Précédent</a>
    </li>
    {% endif %}
    {% for page in pagesInRange %}
        {% if page != current %}
            <li class="page-item " aria-current="page">
            <a href="{{ path(route, query|merge({(pageParameterName):page})) }}" class="page-link">{{page }} </a>
            </li>
        {% else %}
            <li class="page-item active" aria-current="page">
            <a style="background:skyblue" class="page-link disabled" href="{{ path(route, query|merge({(pageParameterName):page})) }}"> {{page }}</a>
            </li>
        {% endif %}
   {% endfor %}
    {% if next is defined %}
    <li class="page-item">
      <a href="{{ path(route, query|merge({(pageParameterName):next})) }}" class="page-link">Suivant</a>
    </li>
    {% endif %}
  </ul>
</nav>
{% endif %}