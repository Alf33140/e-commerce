{% extends 'base.html.twig' %}

{% block title %}Gestion des Utilisateurs{% endblock %}

{% block body %}
    <div class="container">
       
            <h2> Gestion des Utilisateurs</h2>
            
            {% for user in users %}
                <table class= "table">
                        <tr>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Email</th>
                            <th>Roles</th>
                            <th>Actions</th>
                        </tr>
                            <td>{{ user.firstName }}</td>
                            <td>{{ user.lastName }}</td>
                            <td>{{ user.email }}</td>
                            <td>

                            {% if ('ROLE_ADMIN' in user.roles) %}
                                <span class="text-primary">Administrateur</span>
                                
                            {% elseif ('ROLE_USER' in user.roles) %}
                                <span class="text-secondary">Redacteur</span>
                            {% else %}
                                <span class="text-secondary">Utilisateur</span>
                            {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('app_user_set_roles', {'id': user.id}) }}" class="btn btn-primary">Modifier les Rôles</a>
                                <a href="" class="btn btn-danger"> Supprimer</a>
                            </td>
                            {% endfor %}
                            
                            
                </table>
            
    </div>
{% endblock %}
