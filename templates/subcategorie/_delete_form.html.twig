<form method="post" action="{{ path('app_subcategorie_delete', {'id': subcategorie.id}) }}" onsubmit="return confirm('Voulez vous supprimer cet item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ subcategorie.id) }}">
    <button class="btn btn-danger">Supprimer</button>
</form>
