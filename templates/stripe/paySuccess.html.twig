{% extends 'base.html.twig' %}

{% block title %}Paiement de la Commande{% endblock %}

{% block body %}
    <div class="container d-flex justify-content-center mt-5">
        
        <div class="bg-white rounded-lg shadow p-5 text-center" style="max-width: 600px; width: 100%;">
            
            <div class="mb-4 d-flex justify-content-center">
                <div class="mb-4">
                    <img src="{{ asset('uploads/success.jpg') }}" class="img-fluid" alt="Succès" style="max-height: 150px;">
                </div>
            </div>
                    
            <h2 class="text-success font-weight-bold mb-4">Le paiement a été réalisé avec succès</h2>
            
            <p class="text-muted mb-5">
                Merci pour votre confiance.
            </p>
            <p class="text-muted mb-5">
                Votre commande est en cours de préparation.
            </p>
                <div class="mb-4">
                    <img src="{{ asset('uploads/preparebox.jpg') }}" class="img-fluid img-thumbnail" 
                        style="width: 80px; height: 80px; object-fit: cover;">
                </div>
            <div class="mt-4">
                <a href="{{ path('app_home_page') }}" class="btn btn-success btn-lg px-5">Retour à l'accueil</a>
            </div>
            
        </div>
    </div>
{% endblock %}